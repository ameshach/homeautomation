# ============================================================
# Home Automation — sensitive configuration
# ============================================================
# Copy this file to .env and fill in all values.
# .env is gitignored and NEVER committed to the repo.
# Run  scripts/apply-config.sh  after editing .env to
# render template files and validate everything is set.
# ============================================================

# --- WhatsApp gateway ---
WA_GATEWAY_NUMBER=+XXXXXXXXXXX       # Dedicated WhatsApp number (not personal)
WA_GROUP_ID=                         # WhatsApp group ID — find in Hermes logs after first join
WA_ALLOWED_SENDERS=+XXXXXXXXXXX,+XXXXXXXXXXX   # Comma-separated family numbers that may control devices

# --- DeepSeek LLM ---
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Home Assistant ---
HA_URL=http://X.X.X.X:XXXX          # HA address reachable from inside deployer container
HA_TOKEN=                            # Long-lived token from the dedicated deployer HA user (not admin)
HA_CONFIG_PATH=/path/to/homeassistant/config  # NAS host path, bind-mounted into deployer

# --- Deployer / Git ---
REPO_URL=https://github.com/ameshach/homeautomation.git
POLL_SECONDS=30
